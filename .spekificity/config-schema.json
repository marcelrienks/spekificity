{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Spekificity Platform Configuration Schema v1.0",
  "description": "Orchestration state and configuration for spekificity-enabled projects",
  "type": "object",
  "required": [
    "spek_version",
    "spek_initialized",
    "spek_initialized_timestamp",
    "spek_platform_branch"
  ],
  "properties": {
    "spek_version": {
      "type": "string",
      "description": "Spekificity platform version (semantic versioning)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "1.1.0"]
    },
    "spek_initialized": {
      "type": "boolean",
      "description": "Whether spekificity platform has been fully initialized in this project"
    },
    "spek_initialized_timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of last successful initialization",
      "format": "date-time",
      "examples": ["2026-05-03T14:30:00Z"]
    },
    "spek_platform_branch": {
      "type": "string",
      "description": "Git feature branch where spekificity platform is being developed",
      "examples": ["002-spek-platform-lifecycle"]
    },
    "spek_schema_version": {
      "type": "string",
      "description": "Configuration schema version (for migration support)",
      "default": "1.0"
    },
    "tools": {
      "type": "object",
      "description": "Third-party tool integration status",
      "properties": {
        "speckit": {
          "type": "object",
          "properties": {
            "installed": { "type": "boolean" },
            "version": { "type": "string" },
            "initialized": { "type": "boolean" },
            "initialized_timestamp": { "type": "string", "format": "date-time" },
            "last_update": { "type": "string", "format": "date-time" }
          }
        },
        "graphify": {
          "type": "object",
          "properties": {
            "installed": { "type": "boolean" },
            "version": { "type": "string" },
            "initialized": { "type": "boolean" },
            "initialized_timestamp": { "type": "string", "format": "date-time" },
            "vault_location": { "type": "string" }
          }
        },
        "obsidian": {
          "type": "object",
          "properties": {
            "installed": { "type": "boolean" },
            "version": { "type": "string" },
            "optional": { "type": "boolean", "default": true },
            "initialized": { "type": "boolean" },
            "vault_location": { "type": "string" }
          }
        },
        "caveman": {
          "type": "object",
          "properties": {
            "available": { "type": "boolean" },
            "integrated": { "type": "boolean" },
            "last_check": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "description": "Skill installation tracking",
      "properties": {
        "spekificity_installed": { "type": "boolean" },
        "speckit_installed": { "type": "boolean" },
        "caveman_installed": { "type": "boolean" },
        "last_skill_index_update": { "type": "string", "format": "date-time" }
      }
    },
    "spek_custom_preferences": {
      "type": "object",
      "description": "User customization settings (preserved across updates)",
      "additionalProperties": true
    },
    "orchestration_history": {
      "type": "array",
      "description": "Audit trail of setup/init/update operations",
      "items": {
        "type": "object",
        "properties": {
          "operation": { "type": "string", "enum": ["setup", "init", "update"] },
          "step": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "failure", "skipped"] },
          "timestamp": { "type": "string", "format": "date-time" },
          "error_message": { "type": ["string", "null"] }
        }
      }
    }
  },
  "examples": [
    {
      "spek_version": "1.0.0",
      "spek_initialized": true,
      "spek_initialized_timestamp": "2026-05-03T14:30:00Z",
      "spek_platform_branch": "002-spek-platform-lifecycle",
      "spek_schema_version": "1.0",
      "tools": {
        "speckit": {
          "installed": true,
          "version": "0.1.0",
          "initialized": true,
          "initialized_timestamp": "2026-05-03T14:30:00Z"
        },
        "graphify": {
          "installed": true,
          "version": "1.0.0",
          "initialized": true,
          "vault_location": ".obsidian"
        },
        "obsidian": {
          "installed": false,
          "optional": true,
          "initialized": false
        },
        "caveman": {
          "available": true,
          "integrated": true
        }
      },
      "skills": {
        "spekificity_installed": true,
        "speckit_installed": true,
        "caveman_installed": true
      },
      "orchestration_history": []
    }
  ]
}
